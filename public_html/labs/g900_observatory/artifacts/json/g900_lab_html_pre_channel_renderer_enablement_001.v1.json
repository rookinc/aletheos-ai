{
  "schema": "g900.lab_html_backup_before_channel_renderer_enablement",
  "version": 1,
  "created_utc": "2026-06-18T03:43:56Z",
  "source_path": "public_html/labs/g900_observatory/lab.html",
  "lab_html_sha256": "5a10a18bc6563446a0d364d5984b8a41db580e0a75831c82b9eeb5aebc2edeb7",
  "lab_html": "<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>G900 Witness Observatory | Aletheos Labs</title>\n  <link rel=\"stylesheet\" href=\"lab.css\" />\n</head>\n<body>\n  <main class=\"lab-shell\">\n    <header class=\"lab-hero\">\n      <p class=\"eyebrow\">Aletheos Labs</p>\n      <h1>G900 Witness Observatory</h1>\n      <p class=\"lede\">Blank rebuild stage for the G900 viewer.</p>\n    <details class=\"g900-header-instructions g900-boundary-note-card\" id=\"g900-unsupported-phase-step-card\" aria-label=\"G900 instructions and 6/9 anomaly note\">\n<!-- BEGIN G900 SHEETS PER SECOND UI NOTE 001 -->\n<div class=\"g900-instruction-note g900-sheets-sec-note\" id=\"g900-sheets-sec-boundary-note\" aria-label=\"Sheets per second boundary\">\n  <div class=\"g900-sheets-sec-kicker\">Timing boundary</div>\n  <p><strong>Sheets/sec:</strong> quartz keeps the seconds; the grammar earns the sheets.</p>\n  <p>Sheets are admissible grammar steps. Seconds are scaled quartz oscillations. This is a readout, not an event authority.</p>\n  <p class=\"g900-sheets-sec-boundary\">Timers, frames, counters, and renderers do not open gates or light markers.</p>\n</div>\n<!-- END G900 SHEETS PER SECOND UI NOTE 001 -->\n\n  <summary>\n    <span class=\"g900-header-instructions-label\">Instructions</span>\n    <span class=\"g900-header-instructions-chip\">6/9 boundary note</span>\n  </summary>\n  <div id=\"g900-unsupported-phase-step-note\" class=\"g900-boundary-note-body\">\n    Loading audited note...\n  </div>\n</details>\n\n</header>\n\n    <section class=\"stage-card\" aria-label=\"G900 blank stage\">\n      <div class=\"stage-toolbar\">\n        <div class=\"sheet-stepper-controls\">\n          <div class=\"sheet-button-row\">\n            <button id=\"step-back-btn\" class=\"mini-transport-btn\" type=\"button\" aria-label=\"Step back one sheet\">&lt;&lt;</button>\n            <button id=\"play-toggle\" class=\"mini-transport-btn\" type=\"button\" aria-label=\"Play sheet clock\">&#9654;</button>\n            <button id=\"reset-stage-btn\" class=\"mini-transport-btn\" type=\"button\" aria-label=\"Reset stage\">&#8635;</button>\n            <button id=\"step-forward-btn\" class=\"mini-transport-btn\" type=\"button\" aria-label=\"Step forward one sheet\">&gt;&gt;</button>\n\n            <button class=\"mini-transport-btn\" type=\"button\" data-view-mode=\"x\" aria-label=\"X view\">X</button>\n            <button class=\"mini-transport-btn\" type=\"button\" data-view-mode=\"y\" aria-label=\"Y view\">Y</button>\n            <button class=\"mini-transport-btn\" type=\"button\" data-view-mode=\"z\" aria-label=\"Z view\">Z</button>\n            <button class=\"mini-transport-btn angle-preset-btn\" type=\"button\" data-view-mode=\"iso\" aria-label=\"Isometric view\">ISO</button>\n            <label class=\"mini-transport-btn stage-pill stage-grid-toggle\" title=\"Stage Grid\" aria-label=\"Toggle stage grid\">\n              <input id=\"stage-grid-toggle\" type=\"checkbox\" />\n              <span class=\"stage-pill-label\">#</span>\n            </label>\n          </div>\n\n          <div class=\"sheet-rate-head\">\n            <div class=\"sheet-rate-left\">\n              <label for=\"sheet-rate-slider\">Sheets/sec</label>\n              <span id=\"sheet-rate-readout\">333.00</span>\n            </div>\n            <span id=\"sheet-counter-readout\">Sheet 0</span>\n          </div>\n\n          <input id=\"sheet-rate-slider\" type=\"range\" min=\"0.25\" max=\"960\" step=\"0.25\" value=\"333\" />\n</div>\n      </div>\n\n      <div class=\"stage-frame\">\n        <canvas id=\"stage-canvas\" aria-label=\"Blank G900 canvas\"></canvas>\n          <div class=\"stage-grab-bar\" aria-hidden=\"true\">\n            <span></span>\n            <span></span>\n            <span></span>\n          </div>\n\n</div>\n</section>\n\n    <section class=\"lab-note\">\n            <div class=\"layer-panel\" data-layer-panel=\"graph\" aria-label=\"Graph layer controls\">\n        <div class=\"layer-panel-head\">\n          <div>\n            <p class=\"layer-panel-eyebrow\">Layer 1</p>\n            <h2>Graph</h2>\n          </div>\n          <label class=\"layer-switch\">\n            <input id=\"graph-layer-toggle\" data-layer-toggle=\"graph\" type=\"checkbox\" checked />\n            <span>On</span>\n          </label>\n        </div>\n\n        <label class=\"layer-slider-row\" for=\"graph-vertices-slider\">\n          <span>Vertices</span>\n          <input id=\"graph-vertices-slider\" data-layer-range=\"vertices\" type=\"range\" min=\"0\" max=\"100\" step=\"1\" value=\"72\" />\n          <output id=\"graph-vertices-readout\">72</output>\n        </label>\n\n        <label class=\"layer-slider-row\" for=\"graph-edges-slider\">\n          <span>Edges</span>\n          <input id=\"graph-edges-slider\" data-layer-range=\"edges\" type=\"range\" min=\"0\" max=\"100\" step=\"1\" value=\"18\" />\n          <output id=\"graph-edges-readout\">18</output>\n        </label>\n      </div>\n</section>\n<section class=\"lab-note state-console-section\" aria-label=\"G900 state console\">\n      <div class=\"layer-panel\" data-layer-panel=\"carriers\" aria-label=\"Carrier layer controls\">\n        <div class=\"layer-panel-head\">\n          <div>\n            <p class=\"layer-panel-eyebrow\">Layer 2</p>\n            <h2>Carriers</h2>\n          </div>\n          <label class=\"layer-switch\">\n            <input id=\"carrier-render-toggle\" data-layer-toggle=\"carriers\" type=\"checkbox\" />\n            <span>Off</span>\n          </label>\n        </div>\n\n        <label class=\"layer-slider-row\" for=\"carrier-render-family-select\">\n          <span>Family</span>\n          <select id=\"carrier-render-family-select\" data-layer-select=\"carriers\">\n            <option value=\"smoke\">Smoke rail</option>\n            <option value=\"slot_internal\">Slot internal carriers</option>\n            <option value=\"slot_pair_boundary\">Slot-pair boundary carriers</option>\n            <option value=\"all\">All admitted carriers</option>\n          </select>\n          <output id=\"carrier-render-family-readout\">smoke</output>\n        </label>\n\n        <p class=\"layer-panel-note\">Layer 2 carrier readings. Rendering only. Body unchanged.</p>\n      </div>\n\n      <div class=\"layer-panel\" data-layer-panel=\"channels\" aria-label=\"Channel layer controls\">\n        <div class=\"layer-panel-head\">\n          <div>\n            <p class=\"layer-panel-eyebrow\">Layer 3</p>\n            <h2>Channels</h2>\n          </div>\n          <span class=\"layer-status-pill\">Scaffold</span>\n        </div>\n\n        <label class=\"layer-slider-row\" for=\"channel-count-readout\">\n          <span>Admitted</span>\n          <output id=\"channel-count-readout\">0</output>\n        </label>\n\n        <p class=\"layer-panel-note\">Layer 3 channel scaffold. Zero admitted channel readings. No rendering authority.</p>\n      </div>\n\n      <div class=\"stage-console-panel\">\n        <div class=\"stage-console-head\">\n          <span>State Object</span>\n          <a id=\"download-state-json\" class=\"stage-console-action\" href=\"#\" download=\"g900_viewer_state.json\">Download JSON</a>\n        </div>\n        <pre id=\"viewer-state-object\" class=\"viewer-state-object\">{}</pre>\n      </div>\n    </section>\n\n<section id=\"g900-marker-layer-panel-stub\" class=\"g900-marker-layer-panel-stub\" aria-label=\"Marker layer panel stub\">\n  <div class=\"g900-marker-layer-panel-stub__eyebrow\">Layer stub</div>\n  <div class=\"g900-marker-layer-panel-stub__head\">\n    <h2>Markers</h2>\n    <span class=\"g900-marker-layer-panel-stub__pill\">Reserved</span>\n  </div>\n  <p>\n    Marker readings are now receipted as isolated diagnostics, but the live Observatory stage does not load or render them yet.\n  </p>\n  <dl class=\"g900-marker-layer-panel-stub__facts\">\n    <dt>Status</dt>\n    <dd>stub only</dd>\n    <dt>Marker</dt>\n    <dd>unsupported_phase_step_6_9</dd>\n    <dt>Edges</dt>\n    <dd>60 existing body edges</dd>\n    <dt>Vertices</dt>\n    <dd>120 existing body vertices</dd>\n    <dt>Live render</dt>\n    <dd>off</dd>\n    <dt>Channels</dt>\n    <dd>0 admitted</dd>\n  </dl>\n  <p class=\"g900-marker-layer-panel-stub__boundary\">\n    Boundary: this panel is a UI placeholder only. It adds no graph edges, no graph vertices, no marker renderer, no channel, and no physics or force claim.\n  </p>\n</section>\n\n</main>\n<footer class=\"lab-footer\">\n    <p>2026 Centre of Recursive Inquiry. Aletheos.ai is the public research surface for CoRI and Thalean Action Theory.</p>\n  </footer>\n\n  <script type=\"module\" src=\"g900_grammar_stage_v0.js?v=channel-scaffold-001\"></script>\n  <script src=\"kernel/g900_unsupported_phase_step_note.js\" defer></script>\n</body>\n</html>\n\n"
}
